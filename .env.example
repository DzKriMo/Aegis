# copy to .env and edit
AEGIS_ENV=dev
AEGIS_GUARDRAIL_PROFILE=balanced
AEGIS_STRICT_POLICY_LOAD=true
DATABASE_URL=sqlite:///aegis.db
AEGIS_API_KEY=changeme
AEGIS_FAIL_CLOSED=false
POLICY_PATH=config/policies.example.yaml
AEGIS_CORS_ORIGINS=*
AEGIS_RATE_LIMIT_BACKEND=memory
AEGIS_RATE_LIMIT_LIMIT=60
AEGIS_RATE_LIMIT_WINDOW_SECONDS=60
AEGIS_RATE_LIMIT_SQLITE_PATH=aegis_rate_limit.db
AEGIS_RATE_LIMIT_REDIS_URL=redis://127.0.0.1:6379/0
AEGIS_RATE_LIMIT_REDIS_PREFIX=aegis:ratelimit
AEGIS_SEMANTIC_ENABLED=false
AEGIS_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
AEGIS_DB_ENABLED=true
AEGIS_LLM_ENABLED=false
AEGIS_LLM_ENDPOINT=http://127.0.0.1:8080/v1/chat/completions
AEGIS_LLM_TIMEOUT=12
AEGIS_LLM_MODEL=qwen2.5-3b-instruct
AEGIS_LOCAL_CLASSIFIER_ENABLED=false
AEGIS_LOCAL_CLASSIFIER_PATH=models/guardrail_lr.joblib
AEGIS_LOCAL_BLOCK_THRESHOLD=0.78
AEGIS_LOCAL_WARN_THRESHOLD=0.64
AEGIS_LOCAL_APPEAL_LLM_ENABLED=false
AEGIS_LOCAL_APPEAL_CONF_THRESHOLD=0.62
AEGIS_QUARANTINE_THRESHOLD=0.95
AEGIS_OOD_WARN_THRESHOLD=0.72
AEGIS_ACTION_RISK_APPROVAL_THRESHOLD=0.75
AEGIS_ACTION_RISK_BLOCK_THRESHOLD=1.1
AEGIS_TELEMETRY_ENABLED=true
AEGIS_TELEMETRY_PATH=
AEGIS_JWT_SECRET=dev-secret-change
AEGIS_JWT_ISSUER=aegis
AEGIS_JWT_EXP_MINUTES=120
AEGIS_OTEL_ENABLED=false
